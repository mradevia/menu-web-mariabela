# ============================================================================
#  Plantilla de variables de entorno — Maria Bela
#  Copia este archivo a .env.local y rellena los valores reales.
#  (.env.local está git-ignored; este .env.example SÍ se versiona, sin secretos)
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# SERVER-ONLY. Nunca con prefijo NEXT_PUBLIC_. Solo scripts/servidor.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- Fuente de datos del menú: local | supabase ----------------------------
NEXT_PUBLIC_DATA_SOURCE=local
